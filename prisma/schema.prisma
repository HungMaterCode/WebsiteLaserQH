generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          Role      @default(USER)
  password      String?
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Project {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  category        Category
  categoryLabel   String
  eventType       String
  location        String
  scale           String
  year            Int
  heroImage       String
  thumbnailImage  String
  description     String
  fullDescription String
  equipment       Json
  gallery         String[]
  highlight       String
  client          String
  duration        String
  color           String
  sortOrder       Int      @default(0)
  published       Boolean  @default(true)
  seoTitle        String?
  seoDesc         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("projects")
}

model SiteSetting {
  id   String @id @default("global")
  data Json   @default("{}")

  @@map("site_settings")
}

model MediaSetting {
  id   String @id @default("global")
  data Json   @default("{}")

  @@map("media_settings")
}

model Message {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  date      String?
  notes     String?
  projectId String?
  status    String   @default("unread")
  createdAt DateTime @default(now())

  @@map("messages")
}

enum Role {
  USER
  ADMIN
}

enum Category {
  vip
  medium
  mega
}

enum PostStatus {
  draft
  published
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String     @db.Text
  content     String     @db.Text
  coverImage  String
  publishedAt DateTime   @default(now())
  author      String     @default("Admin")
  status      PostStatus @default(draft)
  tags        String[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("posts")
}
